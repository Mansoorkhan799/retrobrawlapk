# Magic Brawl APK download URL (required for download buttons).
# Set to your actual APK download link.
# NEXT_PUBLIC_DOWNLOAD_URL=https://example.com/magic-brawl.apk

# Google Analytics 4 measurement ID (optional).
# Get it from https://analytics.google.com/ → Admin → Data Streams → your web stream.
# Leave unset or set to G-XXXXXXXXXX to disable GA scripts.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
